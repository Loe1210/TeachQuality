<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.vtmer.microteachingquality.mapper.ClazzEvaluationUserMapper">
    <select id="selectClazzId" resultType="java.lang.Integer">
        select clazz_id
        from clazz_evaluation_user
        where user_id = #{userId}
    </select>
</mapper>